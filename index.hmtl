<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>DoorDash Sequence Fix</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Open+Sans:wght@400;600;700;800&display=swap');
        body { font-family: 'Open Sans', sans-serif; overflow: hidden; background: #ffffff; }
        .dd-red { background-color: #FF3008; }
        .dd-teal { background-color: #008289; }
        .ios-status-bar { height: 44px; display: flex; justify-content: space-between; padding: 0 28px; align-items: center; font-weight: 700; font-size: 15px; }
        .map-bg { background: #e5e7eb url('https://map.style/api/v1/static?style=standard&lat=40.5833&lng=-122.3917&zoom=11&size=600x1000') no-repeat center; background-size: cover; flex-grow: 1; position: relative; }
        .floating-btn { width: 44px; height: 44px; background: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; box-shadow: 0 2px 8px rgba(0,0,0,0.12); font-size: 24px; }
        .bottom-sheet { background: white; border-top-left-radius: 32px; border-top-right-radius: 32px; padding: 32px 24px; box-shadow: 0 -4px 16px rgba(0,0,0,0.08); }
        .segmented-control { background: #F6F6F6; border-radius: 999px; padding: 4px; display: flex; }
        .tab { flex: 1; text-align: center; padding: 10px 0; font-size: 14px; font-weight: 700; color: #494949; }
        .tab-active { background: #191919; color: white; border-radius: 999px; }
        .hidden { display: none !important; }
    </style>
</head>
<body>

<div id="app-container" class="h-screen w-screen flex flex-col relative">

    <div id="dashboard" class="flex flex-col h-full">
        <div class="ios-status-bar fixed w-full z-10">
            <span>2:46 <span class="text-[10px] ml-1">🏠</span></span>
            <div class="flex gap-1.5 items-center"><span>📶</span><span>80</span><div class="w-5 h-2.5 border border-green-500 rounded-sm p-[1px]"><div class="bg-green-500 h-full w-full"></div></div></div>
        </div>
        <div class="map-bg">
            <div class="absolute top-16 left-4 flex justify-between w-[92%]">
                <div onclick="resetAndStep()" class="floating-btn cursor-pointer">≡</div>
                <div class="bg-white px-6 py-1.5 rounded-full shadow-md border text-center"><div class="text-[9px] text-gray-500 uppercase font-extrabold">This week</div><div class="font-bold text-[17px] leading-none">$276.69</div></div>
            </div>
            <div class="absolute bottom-0 w-full bottom-sheet">
                <h1 class="text-[34px] font-extrabold leading-[1.1] tracking-tight mb-8">Stay busy with lots<br>of offers</h1>
                <div class="flex gap-3">
                    <button class="dd-red text-white flex-grow py-4 rounded-full font-bold text-[20px]">Dash</button>
                    <button onclick="showPage('schedule-page')" class="bg-[#F0F0F0] p-4 rounded-full">
                        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#191919" stroke-width="2.5"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div id="schedule-page" class="hidden flex flex-col h-full bg-white">
        <div class="ios-status-bar"><span>10:48</span><div class="flex gap-1">📶<span>80</span></div></div>
        <div class="px-5 py-3 flex justify-between items-center">
            <button onclick="resetAndStep()" class="text-3xl font-light">≡</button>
            <h2 class="text-xl font-extrabold">Schedule</h2>
            <div class="flex gap-5 text-xl font-bold"><span>⚙️</span><span>❓</span></div>
        </div>
        <div class="flex justify-between px-6 py-4 text-[12px] font-bold text-gray-400">
            <div class="flex flex-col items-center gap-2"><span>FR</span><span class="bg-[#191919] text-white rounded-full w-10 h-10 flex items-center justify-center">1</span></div>
            <div class="flex flex-col items-center gap-2"><span>SA</span><span>2</span></div><div class="flex flex-col items-center gap-2"><span>SU</span><span>3</span></div><div class="flex flex-col items-center gap-2"><span>MO</span><span>4</span></div><div class="flex flex-col items-center gap-2"><span>TU</span><span>5</span></div>
        </div>
        <div class="px-4 mb-4"><div class="segmented-control"><div class="tab tab-active">Offers</div><div class="tab">Dash</div><div class="tab">My Schedule</div></div></div>
        <div id="schedule-content" class="flex-grow"></div>
    </div>

    <div id="offer-modal" class="hidden absolute inset-0 flex flex-col z-50 bg-white">
        <div class="ios-status-bar"><span>2:22</span><div class="flex gap-1">📶<span>80</span></div></div>
        <div class="map-bg relative h-1/3"><button onclick="resetAndStep()" class="absolute top-4 left-4 floating-btn">≡</button></div>
        <div class="dd-teal p-3.5 text-white flex items-center gap-2 font-bold text-[14px]"><span>✨</span> This is an offer for May 3</div>
        <div id="offer-details" class="flex-grow p-6"></div>
        <div class="p-6"><button onclick="showPage('confirmed-page')" class="dd-red text-white w-full py-4 rounded-full font-bold text-xl shadow-lg">Claim and schedule</button></div>
    </div>

    <div id="confirmed-page" class="hidden flex flex-col h-full bg-white items-center justify-center p-12 text-center">
        <div class="w-24 h-24 bg-green-50 text-green-500 rounded-full flex items-center justify-center text-5xl mb-6 font-bold">✓</div>
        <h2 class="text-4xl font-extrabold mb-3">Confirmed</h2>
        <button onclick="resetAndStep()" class="bg-[#F0F0F0] px-10 py-4 rounded-full font-extrabold text-lg">Next Scenario</button>
    </div>

</div>

<script>
    // Sequence Logic: 0 = IMG_0629, 1 = IMG_0606, 2 = IMG_0607
    let stage = 0;
    let offerData = { pay: "40.13", miles: "12.3", items: "1" };

    function resetAndStep() {
        stage = (stage + 1) % 3;
        showPage('dashboard');
    }

    function showPage(id) {
        document.querySelectorAll('#app-container > div').forEach(p => p.classList.add('hidden'));
        document.getElementById(id).classList.remove('hidden');
        if(id === 'schedule-page') renderSchedule();
        if(id === 'offer-modal') renderOfferCard();
    }

    function renderSchedule() {
        const cont = document.getElementById('schedule-content');
        if(stage === 0) {
            // IMG_0629: Nothing available
            cont.innerHTML = `<div class="flex flex-col items-center justify-center h-[60%] px-10 text-center"><img src="https://em-content.zobj.net/source/apple/354/hamburger_1f354.png" class="w-32 h-32 mb-10"><p class="text-[22px] font-bold text-[#191919] leading-tight mb-8">There's nothing available to schedule today. Check again later.</p></div>`;
        } else if (stage === 1) {
            // IMG_0606: Nothing available + See next
            cont.innerHTML = `<div class="flex flex-col items-center justify-center h-[60%] px-10 text-center"><img src="https://em-content.zobj.net/source/apple/354/hamburger_1f354.png" class="w-32 h-32 mb-10"><p class="text-[22px] font-bold text-[#191919] leading-tight mb-8">There's nothing available to schedule today.</p><button onclick="stage=2; renderSchedule();" class="bg-[#F0F0F0] text-[#191919] font-extrabold px-10 py-3.5 rounded-full text-[17px]">See next available</button></div>`;
        } else {
            // IMG_0607: Offer List
            cont.innerHTML = `<div class="px-5 pt-2"><p class="text-gray-500 font-bold text-sm mb-6 uppercase">CA: Redding</p><div onclick="showPage('offer-modal')" class="flex justify-between items-start cursor-pointer border-b border-gray-100 pb-6"><div><h3 class="text-[28px] font-extrabold leading-none mb-1">$${offerData.pay} offer</h3><p class="text-[#494949] text-[19px] font-bold leading-tight">Chipotle - Redding • Catering</p><p class="text-gray-500 font-bold text-sm mt-1">Pick up by 1:54 PM • est. 20 min</p></div><div class="w-14 h-14 bg-[#F6F6F6] rounded-full border flex items-center justify-center text-2xl shadow-sm">🌯</div></div></div>`;
        }
    }

    function renderOfferCard() {
        // IMG_0626: Full Card
        document.getElementById('offer-details').innerHTML = `
            <div class="flex justify-between items-baseline mb-1"><h2 class="text-[46px] font-extrabold tracking-tight">$${offerData.pay}</h2><span class="text-[13px] text-gray-500 font-bold uppercase tracking-tight">Guaranteed</span></div>
            <p class="text-[21px] font-extrabold mb-5 text-gray-800">${offerData.miles} mi • est. 20 min</p>
            <div class="border-b border-gray-100 mb-8"></div>
            <div class="space-y-8">
                <div class="flex gap-5"><span class="text-[#FF3008] text-2xl">👜</span><div><p class="text-[#FF3008] font-black text-[11px] uppercase tracking-wider mb-0.5">Pickup</p><p class="font-extrabold text-[20px] leading-tight">Chipotle - River Crossings Marketplace</p><p class="text-gray-500 font-bold text-[17px]">(${offerData.items} item)</p></div></div>
                <div class="flex gap-5 items-center"><span class="text-2xl">🏠</span><p class="font-extrabold text-[20px]">Customer dropoff</p></div>
            </div>`;
    }
</script>
</body>
</html>
